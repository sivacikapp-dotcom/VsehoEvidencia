# ─────────────────────────────────────────────────────────────────────────────
# Vzorový konfiguračný súbor — skopírujte ako .env a vyplňte reálne hodnoty.
# NIKDY necommitujte .env do git. Tento súbor (.env.example) je bezpečné
# zdieľať, pretože neobsahuje žiadne skutočné heslá ani kľúče.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Databáza ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# V produkcii NIKDY nepoužívajte superuser účet (postgres).
# Vytvorte dedikovaného aplikačného používateľa iba s SELECT/INSERT/UPDATE/DELETE.
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<dbname>?schema=public"

# Priame pripojenie bez ?schema=public — používa sa Prisma migráciami a seed skriptom.
DATABASE_DIRECT_URL="postgresql://<user>:<password>@<host>:5432/<dbname>"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Verejná URL aplikácie (bez lomky na konci).
# V produkcii musí byť https://
NEXTAUTH_URL="https://your-domain.sk"

# Tajný kľúč na podpisovanie a šifrovanie JWT session tokenov.
# Vygenerujte príkazom: openssl rand -base64 32
# Rotujte každých 90 dní alebo pri podozrení na kompromitáciu.
NEXTAUTH_SECRET="<výstup z: openssl rand -base64 32>"

# ─── Šifrovanie citlivých DB polí (AES-256-GCM) ─────────────────────────────
# Kľúč pre field-level šifrovanie (napr. mfaSecret).
# 32 náhodných bajtov zakódovaných v base64.
# Vygenerujte príkazom: openssl rand -base64 32
# NIKDY nerotujte tento kľúč bez predchádzajúcej migrácie (re-encrypt) všetkých
# zašifrovaných riadkov v DB — inak stratíte prístup k dátam.
APP_ENCRYPTION_KEY="<výstup z: openssl rand -base64 32>"

# ─── Seed (len development / staging) ────────────────────────────────────────
# Heslo pre počiatočný admin účet vytvorený cez: npm run seed
# Minimálne 10 znakov, aspoň 1 veľké písmeno, 1 malé a 1 číslica.
# V produkcii túto premennú NENASTAVUJTE — seed sa v produkcii nespúšťa.
SEED_ADMIN_PASSWORD="<min10znakov_VelkeAMale1>"
